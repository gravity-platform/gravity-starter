{
  "name": "gravity-starter",
  "version": "1.0.0",
  "private": true,
  "description": "Gravity Platform Starter Template",
  "packageManager": "npm@10.2.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "gen:nodes": "npm run gen:nodes -w @gravity-platform/design-system-dev && npm run build -w @gravity-platform/design-system"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
